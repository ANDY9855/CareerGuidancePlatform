@model List<CareerGuidancePlatform.Models.Notification>
@{ ViewData["Title"] = "Notifications"; }

<div class="page-header">
    <div class="container">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
            <div>
                <span class="section-badge">Activity</span>
                <h1 class="text-white fw-bold mt-2">Notifications</h1>
                <p class="text-muted">Stay up to date with your sessions and mentors</p>
            </div>
            @if (Model.Any(n => !n.IsRead))
            {
                <form asp-action="MarkAllRead" method="post">
                    <button type="submit" class="btn btn-outline-primary">
                        <i class="bi bi-check2-all me-2"></i>Mark All as Read
                    </button>
                </form>
            }
        </div>
    </div>
</div>

<section>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                @if (!Model.Any())
                {
                    <div class="card-glass text-center py-5">
                        <i class="bi bi-bell-slash fs-1 text-muted d-block mb-3"></i>
                        <h5 class="text-white fw-bold">No notifications yet</h5>
                        <p class="text-muted small">When your mentor confirms or updates a session, you'll see it here.</p>
                    </div>
                }
                else
                {
                    @foreach (var n in Model)
                    {
                        <form asp-action="MarkRead" asp-route-id="@n.Id" method="post" class="mb-3">
                            <button type="submit" class="w-100 text-start" style="background:none;border:none;padding:0;">
                                <div class="card-glass @(n.IsRead ? "" : "border-gradient")"
                                     style="@(n.IsRead ? "opacity:0.7;" : "border-color:rgba(255,45,107,0.4);")">
                                    <div class="d-flex align-items-start gap-3">
                                        <div class="feature-icon flex-shrink-0" style="width:46px;height:46px;font-size:1.2rem">
                                            <i class="bi @n.Icon @n.IconColor"></i>
                                        </div>
                                        <div class="flex-grow-1">
                                            <div class="d-flex justify-content-between align-items-start gap-2">
                                                <div>
                                                    <h6 class="text-white fw-semibold mb-1">@n.Title
                                                        @if (!n.IsRead)
                                                        {
                                                            <span class="tag tag-blue ms-2" style="font-size:0.65rem;padding:0.15rem 0.5rem">NEW</span>
                                                        }
                                                    </h6>
                                                    <p class="text-muted small mb-0">@n.Message</p>
                                                </div>
                                                <span class="text-muted" style="font-size:0.72rem;white-space:nowrap">
                                                    @n.CreatedAt.ToString("MMM dd, h:mm tt")
                                                </span>
                                            </div>
                                            @if (!string.IsNullOrEmpty(n.Url))
                                            {
                                                <span class="text-gradient small fw-semibold mt-2 d-block">
                                                    <i class="bi bi-arrow-right-circle me-1"></i>Click to view →
                                                </span>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </button>
                        </form>
                    }
                }
            </div>
        </div>
    </div>
</section>
