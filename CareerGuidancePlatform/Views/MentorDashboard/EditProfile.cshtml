@model CareerGuidancePlatform.Models.Mentor
@{ ViewData["Title"] = "Edit My Profile"; }
@await Html.PartialAsync("_MentorNav")

<div class="page-header">
    <div class="container">
        <a asp-action="Index" class="text-muted small text-decoration-none"><i class="bi bi-arrow-left me-1"></i>Back to Dashboard</a>
        <h1 class="text-white fw-bold mt-2">Edit My Profile</h1>
        <p class="text-muted">Update how mentees see you</p>
    </div>
</div>

<section class="container">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="card-glass">
                <!-- Read-only info -->
                <div class="card-glass mb-4" style="border-color:rgba(6,214,160,0.2);background:rgba(6,214,160,0.04)">
                    <p class="text-muted small mb-1"><i class="bi bi-info-circle me-1"></i>The following fields are managed by admin:</p>
                    <div class="row g-2">
                        <div class="col-md-4"><span class="text-muted small d-block">Name</span><span class="text-white small fw-semibold">@Model.Name</span></div>
                        <div class="col-md-4"><span class="text-muted small d-block">Email</span><span class="text-white small fw-semibold">@Model.Email</span></div>
                        <div class="col-md-4"><span class="text-muted small d-block">Experience</span><span class="text-white small fw-semibold">@Model.YearsOfExperience years</span></div>
                    </div>
                </div>

                <form asp-action="EditProfile" method="post">
                    <input asp-for="Id" type="hidden" />
                    <div class="mb-3">
                        <label class="form-label">Specialization</label>
                        <input asp-for="Specialization" class="form-control" placeholder="e.g. Machine Learning, React, UX Design" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Industry</label>
                        <select asp-for="Industry" class="form-select">
                            <option value="Technology">Technology</option>
                            <option value="Design">Design</option>
                            <option value="Security">Security</option>
                            <option value="Management">Management</option>
                            <option value="Finance">Finance</option>
                            <option value="Healthcare">Healthcare</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Bio</label>
                        <textarea asp-for="Bio" class="form-control" rows="5" placeholder="Tell mentees about your background, expertise, and mentoring style..." required></textarea>
                    </div>
                    <div class="mb-4">
                        <label class="form-label">Availability</label>
                        <input asp-for="Availability" class="form-control" placeholder="e.g. Mon-Fri 6PM-9PM, Weekends 10AM-2PM" />
                    </div>
                    <div class="mb-4">
                        <div class="form-check form-switch">
                            <input asp-for="IsAvailable" class="form-check-input" type="checkbox" />
                            <label class="form-check-label text-muted" asp-for="IsAvailable">
                                Currently accepting new bookings
                            </label>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary w-100 btn-lg">
                        <i class="bi bi-save me-2"></i>Save Profile
                    </button>
                </form>
            </div>
        </div>
    </div>
</section>
