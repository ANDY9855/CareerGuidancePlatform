@{ ViewData["Title"] = "No Mentor Profile"; }
@await Html.PartialAsync("_MentorNav")

<div class="hero-section" style="min-height:60vh">
    <div class="container text-center">
        <i class="bi bi-person-x-fill" style="font-size:4rem;color:var(--accent-gold);display:block;margin-bottom:1.5rem"></i>
        <h2 class="text-white fw-bold mb-3">No Mentor Profile Linked</h2>
        <p class="text-muted mb-4" style="max-width:480px;margin:0 auto">
            Your account has the <span class="tag tag-purple">Mentor</span> role, but no mentor profile matches your email address
            <strong class="text-white">(@User.Identity!.Name)</strong>.
        </p>
        <div class="card-glass d-inline-block text-start p-4 mb-4" style="max-width:420px">
            <h6 class="text-white fw-semibold mb-2"><i class="bi bi-info-circle me-2 text-gradient-gold"></i>What to do?</h6>
            <ol class="text-muted small mb-0" style="padding-left:1.2rem">
                <li class="mb-1">Contact your Admin to create a mentor profile for your email.</li>
                <li class="mb-1">Once linked, return here and your dashboard will appear.</li>
            </ol>
        </div>
        <div class="d-flex gap-3 justify-content-center">
            <a asp-controller="Admin" asp-action="ManageMentors" class="btn btn-primary">
                <i class="bi bi-shield-lock me-2"></i>Go to Admin Panel
            </a>
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary">Back to Home</a>
        </div>
    </div>
</div>
