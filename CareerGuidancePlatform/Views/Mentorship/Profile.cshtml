@model CareerGuidancePlatform.Models.Mentor
@{ ViewData["Title"] = Model.Name + " - Mentor Profile"; }

<div class="page-header">
    <div class="container">
        <a asp-action="Index" class="text-muted small text-decoration-none"><i class="bi bi-arrow-left me-1"></i>Back to Mentors</a>
        <div class="d-flex gap-4 align-items-center mt-3 flex-wrap">
            <div class="mentor-avatar" style="width:80px;height:80px;font-size:2rem">@Model.Name[0]</div>
            <div>
                <h1 class="text-white fw-bold mb-0">@Model.Name</h1>
                <p class="text-muted mb-1">@Model.Specialization</p>
                <div class="d-flex gap-2 flex-wrap">
                    <span class="tag tag-blue">@Model.Industry</span>
                    <span class="tag @(Model.IsAvailable?"tag-green":"tag-red")">@(Model.IsAvailable?"● Available":"● Unavailable")</span>
                </div>
            </div>
        </div>
    </div>
</div>

<section>
    <div class="container">
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="card-glass mb-4">
                    <h5 class="text-white fw-bold mb-3"><i class="bi bi-person me-2 text-gradient"></i>About</h5>
                    <p class="text-muted">@Model.Bio</p>
                </div>
                <div class="card-glass">
                    <h5 class="text-white fw-bold mb-3"><i class="bi bi-calendar3 me-2 text-gradient-gold"></i>Availability &amp; Session Modes</h5>
                    <p class="text-muted"><i class="bi bi-clock me-2"></i>@(Model.Availability ?? "Contact mentor for availability")</p>
                    <div class="d-flex gap-3 mt-3 flex-wrap">
                        <div class="card-glass text-center p-3" style="flex:1">
                            <i class="bi bi-camera-video fs-3 text-gradient d-block mb-1"></i>
                            <span class="text-white small">Video Call</span>
                        </div>
                        <div class="card-glass text-center p-3" style="flex:1">
                            <i class="bi bi-chat-dots fs-3 text-gradient-gold d-block mb-1"></i>
                            <span class="text-white small">Messaging</span>
                        </div>
                        <div class="card-glass text-center p-3" style="flex:1">
                            <i class="bi bi-people fs-3 text-gradient d-block mb-1"></i>
                            <span class="text-white small">Group Session</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <!-- STATS CARD -->
                <div class="card-glass mb-4 text-center">
                    <div class="stars fs-4 mb-2">@string.Concat(Enumerable.Repeat("★",(int)Model.Rating))</div>
                    <span class="text-gradient fw-bold" style="font-size:2rem">@Model.Rating</span>
                    <p class="text-muted small mt-1">out of 5.0</p>
                    <hr style="border-color:var(--border-color)" />
                    <div class="row g-2">
                        <div class="col-6">
                            <span class="text-white fw-bold text-gradient" style="font-size:1.5rem">@Model.TotalSessions</span>
                            <span class="text-muted small d-block">sessions</span>
                        </div>
                        <div class="col-6">
                            <span class="text-white fw-bold text-gradient-gold" style="font-size:1.5rem">@Model.YearsOfExperience+</span>
                            <span class="text-muted small d-block">yrs exp</span>
                        </div>
                    </div>
                </div>

                <!-- ACTION BUTTONS -->
                @if (User.Identity!.IsAuthenticated)
                {
                    <div class="d-grid gap-3">
                        <a asp-action="Book" asp-route-mentorId="@Model.Id" class="btn btn-primary btn-lg">
                            <i class="bi bi-calendar-plus me-2"></i>Book a Session
                        </a>
                        <a asp-action="Chat" asp-route-mentorId="@Model.Id" class="btn btn-outline-primary">
                            <i class="bi bi-chat-dots me-2"></i>Send Message / Chat
                        </a>
                    </div>
                }
                else
                {
                    <div class="d-grid gap-2">
                        <a asp-controller="Account" asp-action="Login" class="btn btn-primary btn-lg">
                            <i class="bi bi-box-arrow-in-right me-2"></i>Login to Book
                        </a>
                        <p class="text-muted small text-center">Login or register to book sessions and message mentors</p>
                    </div>
                }
            </div>
        </div>
    </div>
</section>
