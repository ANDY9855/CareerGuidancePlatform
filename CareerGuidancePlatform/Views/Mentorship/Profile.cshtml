@model CareerGuidancePlatform.Models.Mentor
@{ ViewData["Title"] = Model.Name + " - Mentor Profile"; }

<div class="page-header">
    <div class="container">
        <div class="d-flex gap-4 align-items-center">
            <div class="mentor-avatar" style="width:80px;height:80px;font-size:2rem">@Model.Name[0]</div>
            <div>
                <h1 class="text-white fw-bold mb-0">@Model.Name</h1>
                <p class="text-muted mb-1">@Model.Specialization</p>
                <span class="tag tag-blue">@Model.Industry</span>
            </div>
        </div>
    </div>
</div>

<section>
    <div class="container">
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="card-glass mb-4">
                    <h5 class="text-white fw-bold mb-3"><i class="bi bi-person me-2 text-gradient"></i>About</h5>
                    <p class="text-muted">@Model.Bio</p>
                </div>
                <div class="card-glass">
                    <h5 class="text-white fw-bold mb-3"><i class="bi bi-calendar3 me-2 text-gradient-gold"></i>Availability</h5>
                    <p class="text-muted"><i class="bi bi-clock me-2"></i>@Model.Availability</p>
                    <div class="d-flex gap-3 mt-3 flex-wrap">
                        <div class="card-glass text-center p-3" style="flex:1">
                            <i class="bi bi-camera-video fs-3 text-gradient d-block mb-1"></i>
                            <span class="text-white small">Video Call</span>
                        </div>
                        <div class="card-glass text-center p-3" style="flex:1">
                            <i class="bi bi-chat-dots fs-3 text-gradient-gold d-block mb-1"></i>
                            <span class="text-white small">Messaging</span>
                        </div>
                        <div class="card-glass text-center p-3" style="flex:1">
                            <i class="bi bi-people fs-3 text-gradient d-block mb-1"></i>
                            <span class="text-white small">Group Session</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="card-glass mb-4 text-center">
                    <div class="stars fs-4 mb-2">@string.Concat(Enumerable.Repeat("★",(int)Model.Rating))</div>
                    <span class="text-gradient fw-bold" style="font-size:2rem">@Model.Rating</span>
                    <p class="text-muted small mt-1">out of 5.0</p>
                    <hr style="border-color:var(--border-color)" />
                    <div class="mb-2"><span class="text-white fw-bold text-gradient" style="font-size:1.5rem">@Model.TotalSessions</span><span class="text-muted small d-block">sessions completed</span></div>
                    <div><span class="text-white fw-bold text-gradient-gold" style="font-size:1.5rem">@Model.YearsOfExperience+</span><span class="text-muted small d-block">years experience</span></div>
                </div>
                <a asp-action="Book" asp-route-mentorId="@Model.Id" class="btn btn-primary w-100 btn-lg">
                    <i class="bi bi-calendar-plus me-2"></i>Book a Session
                </a>
            </div>
        </div>
    </div>
</section>
