@model List<CareerGuidancePlatform.Models.MentorMessage>
@{
    ViewData["Title"] = "Chat";
    var mentor = (CareerGuidancePlatform.Models.Mentor)ViewBag.Mentor;
    var mentorId = (int)ViewBag.MentorId;
}

<div class="page-header">
    <div class="container">
        <a asp-action="Profile" asp-route-id="@mentorId" class="text-muted small text-decoration-none">
            <i class="bi bi-arrow-left me-1"></i>Back to Profile
        </a>
        <div class="d-flex align-items-center gap-3 mt-2">
            <div class="mentor-avatar" style="width:52px;height:52px;font-size:1.3rem">@mentor.Name[0]</div>
            <div>
                <h1 class="text-white fw-bold mb-0" style="font-size:1.5rem">@mentor.Name</h1>
                <p class="text-muted mb-0 small">@mentor.Specialization</p>
                <span class="tag @(mentor.IsAvailable?"tag-green":"tag-red")">@(mentor.IsAvailable?"● Online":"● Away")</span>
            </div>
            <div class="ms-auto d-flex gap-2">
                <a asp-action="VideoCall" asp-route-mentorId="@mentorId" class="btn btn-outline-primary btn-sm">
                    <i class="bi bi-camera-video-fill me-1"></i>Video Call
                </a>
                <a asp-action="Book" asp-route-mentorId="@mentorId" class="btn btn-primary btn-sm">
                    <i class="bi bi-calendar-plus me-1"></i>Book Session
                </a>
            </div>
        </div>
    </div>
</div>

<section class="container">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card-glass" style="min-height:520px;display:flex;flex-direction:column">

                <!-- Quick Info Bar -->
                <div class="d-flex gap-3 mb-4 p-3 rounded-xl" style="background:rgba(79,110,247,0.06);border:1px solid var(--border-color)">
                    <div class="text-center flex-grow-1">
                        <div class="text-white fw-bold">@mentor.YearsOfExperience+</div>
                        <div class="text-muted" style="font-size:0.72rem">Years Exp.</div>
                    </div>
                    <div class="text-center flex-grow-1">
                        <div class="text-white fw-bold">@mentor.TotalSessions</div>
                        <div class="text-muted" style="font-size:0.72rem">Sessions</div>
                    </div>
                    <div class="text-center flex-grow-1">
                        <div class="text-gradient-gold fw-bold">★ @mentor.Rating</div>
                        <div class="text-muted" style="font-size:0.72rem">Rating</div>
                    </div>
                    <div class="text-center flex-grow-1">
                        <div class="text-white fw-bold small">@(mentor.Availability ?? "Flexible")</div>
                        <div class="text-muted" style="font-size:0.72rem">Availability</div>
                    </div>
                </div>

                <!-- Chat Thread -->
                <div class="flex-grow-1 mb-4 overflow-auto" style="max-height:380px" id="chatBox">
                    @if (!Model.Any())
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-chat-heart fs-2 text-muted d-block mb-2"></i>
                            <p class="text-muted small">Say hello to @mentor.Name! Send your first message below.</p>
                        </div>
                    }
                    @foreach (var msg in Model)
                    {
                        <div class="d-flex @(msg.IsFromMentor?"justify-content-start":"justify-content-end") mb-3">
                            @if (msg.IsFromMentor)
                            {
                                <div class="mentor-avatar me-2" style="width:32px;height:32px;font-size:0.75rem;flex-shrink:0;align-self:flex-end">@mentor.Name[0]</div>
                            }
                            <div style="max-width:70%">
                                <div class="@(msg.IsFromMentor?"msg-bubble-mentor-u":"msg-bubble-user-u")">
                                    @msg.Content
                                </div>
                                <div class="text-muted mt-1" style="font-size:0.68rem;text-align:@(msg.IsFromMentor?"left":"right")">
                                    @msg.SentAt.ToString("MMM dd h:mm tt")
                                    @if (!msg.IsFromMentor) { <span>@(msg.IsRead?"✓✓":"✓")</span> }
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <!-- Send Message Form -->
                @if ((bool)ViewBag.HasActiveSession)
                {
                    <form id="chatForm" class="d-flex gap-2 mt-auto" onsubmit="sendChat(event)">
                        <input type="hidden" id="mentorId" value="@mentorId" />
                        <input id="chatContent" class="form-control" placeholder="Type a message to @mentor.Name..." autocomplete="off" required />
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="bi bi-send-fill"></i>
                        </button>
                    </form>
                }
                else
                {
                    <div class="alert alert-secondary mt-auto mb-0 text-center" style="background: rgba(255,255,255,0.05); border: 1px solid var(--border-color); color: var(--text-muted);">
                        <i class="bi bi-info-circle me-2"></i>You cannot send messages because your session with this mentor is cancelled or does not exist.
                    </div>
                }

            </div>
        </div>
    </div>
</section>

<style>
.msg-bubble-user-u   { background:var(--gradient-btn); color:white; padding:0.6rem 1rem; border-radius:18px 18px 4px 18px; font-size:0.88rem; word-wrap:break-word; }
.msg-bubble-mentor-u { background:rgba(255,255,255,0.06); border:1px solid var(--border-color); color:var(--text-primary); padding:0.6rem 1rem; border-radius:18px 18px 18px 4px; font-size:0.88rem; word-wrap:break-word; }
</style>
@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
<script>
const box = document.getElementById('chatBox');
if (box) box.scrollTop = box.scrollHeight;

const mentorId = document.getElementById('mentorId').value;
const userId = '@User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value';
const mentorAvatar = '@mentor.Name[0]';

let currentCallRoom = '', currentCallerConn = '';

// Initialize SignalR
const connection = new signalR.HubConnectionBuilder().withUrl("/chatHub").build();
connection.start().then(() => {
    connection.invoke("JoinChat", `Chat_${mentorId}_${userId}`);
    connection.invoke("RegisterUser", userId);
}).catch(err => console.error(err.toString()));

connection.on("IncomingCall", (callerName, callRoomId, callerConnId) => {
    currentCallRoom = callRoomId;
    currentCallerConn = callerConnId;
    document.getElementById('incomingCallerName').textContent = callerName;
    document.getElementById('incomingCallOverlay').style.display = 'flex';
    setTimeout(declineCall, 30000);
});

function acceptCall() {
    window.location.href = `/Mentorship/VideoCall?mentorId=${mentorId}&isCaller=false&callerConnId=${currentCallerConn}`;
}

function declineCall() {
    if (currentCallerConn) {
        connection.invoke("DeclineCall", currentCallerConn).catch(()=>{});
    }
    document.getElementById('incomingCallOverlay').style.display = 'none';
    currentCallRoom = '';
    currentCallerConn = '';
}

// Listen for incoming real-time messages
connection.on("ReceiveMessage", function (msg) {
    let html = '';
    if (msg.isFromMentor) {
        html = `
        <div class="d-flex justify-content-start mb-3">
            <div class="mentor-avatar me-2" style="width:32px;height:32px;font-size:0.75rem;flex-shrink:0;align-self:flex-end">${mentorAvatar}</div>
            <div style="max-width:70%">
                <div class="msg-bubble-mentor-u">${msg.content}</div>
                <div class="text-muted mt-1" style="font-size:0.68rem;text-align:left">${msg.sentAt}</div>
            </div>
        </div>`;
    } else {
        html = `
        <div class="d-flex justify-content-end mb-3">
            <div style="max-width:70%">
                <div class="msg-bubble-user-u">${msg.content}</div>
                <div class="text-muted mt-1" style="font-size:0.68rem;text-align:right">${msg.sentAt} <span>✓</span></div>
            </div>
        </div>`;
    }
    box.insertAdjacentHTML('beforeend', html);
    box.scrollTop = box.scrollHeight;
});

// Send message via AJAX
function sendChat(e) {
    e.preventDefault();
    const contentInput = document.getElementById('chatContent');
    const content = contentInput.value;
    if (!content.trim()) return;

    fetch('@Url.Action("SendMessage", "Mentorship")', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams({ mentorId: mentorId, content: content })
    }).then(res => {
        if(res.ok) contentInput.value = '';
    });
}
</script>
}

<!-- Incoming Call UI for User -->
<div id="incomingCallOverlay" style="display:none;position:fixed;top:20px;right:20px;background:rgba(15,18,25,0.95);border:1px solid rgba(255,255,255,0.1);backdrop-filter:blur(10px);padding:1.5rem;border-radius:12px;z-index:9999;box-shadow:0 10px 30px rgba(0,0,0,0.5);align-items:center;gap:1.5rem;animation:slideInRight 0.4s ease">
    <div style="display:flex;align-items:center;gap:1rem">
        <div class="pulse-ring-small">
            <div style="width:40px;height:40px;background:var(--gradient-btn);border-radius:50%;display:flex;align-items:center;justify-content:center;color:white;font-size:1.2rem"><i class="bi bi-camera-video-fill"></i></div>
        </div>
        <div>
            <div class="text-white fw-bold mb-1">Incoming Video Call</div>
            <div class="text-muted small">from <span id="incomingCallerName" class="text-white"></span></div>
        </div>
    </div>
    <div style="display:flex;gap:0.5rem">
        <button onclick="acceptCall()" class="btn btn-sm" style="background:#06d6a0;color:#000;border:none;font-weight:600;padding:0.4rem 1rem"><i class="bi bi-telephone-fill me-1"></i>Accept</button>
        <button onclick="declineCall()" class="btn btn-sm" style="background:#ff3b30;color:#fff;border:none;font-weight:600;padding:0.4rem 1rem"><i class="bi bi-telephone-x-fill me-1"></i>Decline</button>
    </div>
</div>

<style>
@@keyframes slideInRight { from{transform:translateX(100%);opacity:0} to{transform:translateX(0);opacity:1} }
.pulse-ring-small { position:relative; }
.pulse-ring-small::before { content:''; position:absolute; inset:-8px; border-radius:50%; background:rgba(6,214,160,0.2); border:1px solid rgba(6,214,160,0.5); animation:pulseRingSmall 1.5s infinite; }
@@keyframes pulseRingSmall { 0%,100%{transform:scale(1);opacity:1} 50%{transform:scale(1.2);opacity:0.5} }
</style>
