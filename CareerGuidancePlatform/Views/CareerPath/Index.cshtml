@model List<CareerGuidancePlatform.Models.CareerPath>
@{ ViewData["Title"] = "Career Paths"; }

<div class="page-header">
    <div class="container">
        <span class="section-badge">Career Exploration</span>
        <h1 class="text-white fw-bold mt-2">Career Path Maps</h1>
        <p class="text-muted">Visual roadmaps showing skills, stages, salary info and job outlook</p>
    </div>
</div>

<section>
    <div class="container">
        <div class="row g-4 mb-5">
            @foreach (var p in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <a asp-action="Detail" asp-route-id="@p.Id" style="text-decoration:none">
                        <div class="card-glass h-100">
                            <div class="feature-icon mb-3"><i class="bi @p.IconClass"></i></div>
                            <h5 class="text-white fw-bold mb-1">@p.Title</h5>
                            <span class="tag tag-blue mb-3">@p.Industry</span>
                            <p class="text-muted small mb-3">@p.Description</p>
                            <div class="d-flex gap-3 flex-wrap">
                                <div><i class="bi bi-cash text-gradient me-1"></i><span class="text-muted small">@p.AverageSalary</span></div>
                                <div><i class="bi bi-graph-up text-gradient-gold me-1"></i><span class="text-muted small">@p.JobOutlook</span></div>
                            </div>
                            <div class="mt-3"><span class="text-gradient small fw-semibold">View Roadmap →</span></div>
                        </div>
                    </a>
                </div>
            }
        </div>

        <div class="row g-4">
            <div class="col-md-4">
                <a asp-action="Stories" style="text-decoration:none">
                    <div class="card-glass text-center">
                        <i class="bi bi-stars fs-1 text-gradient-gold d-block mb-3"></i>
                        <h5 class="text-white fw-bold">Success Stories</h5>
                        <p class="text-muted small">Real career journeys from professionals who made it</p>
                        <span class="text-gradient small fw-semibold">Read Stories →</span>
                    </div>
                </a>
            </div>
            <div class="col-md-4">
                <a asp-action="Roles" style="text-decoration:none">
                    <div class="card-glass text-center">
                        <i class="bi bi-person-workspace fs-1 text-gradient d-block mb-3"></i>
                        <h5 class="text-white fw-bold">Job Role Profiles</h5>
                        <p class="text-muted small">In-depth profiles of top job roles with salary and outlook</p>
                        <span class="text-gradient small fw-semibold">Explore Roles →</span>
                    </div>
                </a>
            </div>
            <div class="col-md-4">
                <a asp-controller="Assessment" asp-action="Index" style="text-decoration:none">
                    <div class="card-glass text-center">
                        <i class="bi bi-compass fs-1 text-gradient d-block mb-3"></i>
                        <h5 class="text-white fw-bold">Find Your Path</h5>
                        <p class="text-muted small">Take the assessment to get a personalized recommendation</p>
                        <span class="text-gradient small fw-semibold">Take Quiz →</span>
                    </div>
                </a>
            </div>
        </div>
    </div>
</section>
