@{
    var cur = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
}
<nav class="mentor-subnav">
    <div class="container">
        <div class="admin-nav-inner">
            <span class="admin-nav-label" style="color:#06d6a0"><i class="bi bi-person-video3 me-1"></i>Mentor</span>
            <div class="admin-nav-links">
                <a asp-controller="MentorDashboard" asp-action="Index"       class="mentor-nav-link @(cur=="Index"?"mactive":"")"><i class="bi bi-speedometer2 me-1"></i>Dashboard</a>
                <a asp-controller="MentorDashboard" asp-action="Sessions"    class="mentor-nav-link @(cur=="Sessions"?"mactive":"")"><i class="bi bi-calendar-check me-1"></i>Sessions</a>
                <a asp-controller="MentorDashboard" asp-action="Messages"    class="mentor-nav-link @(cur=="Messages"?"mactive":"")"><i class="bi bi-chat-dots me-1"></i>Messages</a>
                <a asp-controller="MentorDashboard" asp-action="EditProfile" class="mentor-nav-link @(cur=="EditProfile"?"mactive":"")"><i class="bi bi-pencil-square me-1"></i>Edit Profile</a>
                <a asp-controller="Mentorship" asp-action="Index" class="mentor-nav-link"><i class="bi bi-arrow-left me-1"></i>Back to Site</a>
            </div>
        </div>
    </div>
</nav>
<style>
.mentor-subnav { background:rgba(6,214,160,0.06); border-bottom:1px solid rgba(6,214,160,0.25); position:sticky; top:72px; z-index:999; backdrop-filter:blur(12px); }
.mentor-nav-link { color:var(--text-muted); font-size:0.8rem; font-weight:500; padding:0.35rem 0.8rem; border-radius:8px; text-decoration:none; white-space:nowrap; transition:all 0.2s; border:1px solid transparent; }
.mentor-nav-link:hover { color:#06d6a0; background:rgba(6,214,160,0.08); }
.mentor-nav-link.mactive { color:#06d6a0; background:rgba(6,214,160,0.12); border-color:rgba(6,214,160,0.3); }
</style>
