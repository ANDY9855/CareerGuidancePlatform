<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Career Guidance Platform - Personalized career assessments, mentorship, and skill development resources." />
    <title>@ViewData["Title"] - CareerPath</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark fixed-top" id="mainNav">
        <div class="container">
            <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                <i class="bi bi-compass me-2"></i>CareerPath
            </a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navMenu">
                <ul class="navbar-nav mx-auto gap-1">
                    <li class="nav-item"><a class="nav-link" asp-controller="Assessment" asp-action="Index"><i class="bi bi-clipboard-check me-1"></i>Assessment</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Resources" asp-action="Index"><i class="bi bi-book me-1"></i>Resources</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Mentorship" asp-action="Index"><i class="bi bi-people me-1"></i>Mentors</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="CareerPath" asp-action="Index"><i class="bi bi-map me-1"></i>Career Paths</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Jobs" asp-action="Index"><i class="bi bi-briefcase me-1"></i>Jobs</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Goals" asp-action="Index"><i class="bi bi-bullseye me-1"></i>Goals</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Networking" asp-action="Events"><i class="bi bi-calendar-event me-1"></i>Network</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Networking" asp-action="Community"><i class="bi bi-chat-dots me-1"></i>Community</a></li>
                <div class="d-flex gap-2 align-items-center">
                    @if (User.Identity!.IsAuthenticated)
                    {
                        if (User.IsInRole("Admin"))
                        {
                            <a asp-controller="Admin" asp-action="Index" class="btn btn-gold btn-sm me-1 text-dark fw-bold"><i class="bi bi-shield-lock-fill me-1"></i>Admin Panel</a>
                        }
                        if (User.IsInRole("Mentor") && !User.IsInRole("Admin"))
                        {
                            <a asp-controller="MentorDashboard" asp-action="Index" class="btn btn-sm me-2 fw-bold" style="background:rgba(6,214,160,0.15);border:1px solid rgba(6,214,160,0.4);color:#06d6a0"><i class="bi bi-person-video3 me-1"></i>My Dashboard</a>
                        }
                        <!-- Notification Bell -->
                        <div class="dropdown ms-2" id="notifDropdown">
                            <a class="btn btn-outline-light btn-sm position-relative" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false" id="notifBell">
                                <i class="bi bi-bell-fill"></i>
                                <span id="notifBadge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size:0.6rem;display:none">0</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end" id="notifList" style="width:320px;background:rgba(15,18,25,0.97);border:1px solid rgba(255,255,255,0.1);backdrop-filter:blur(12px)">
                                <li class="px-3 py-2 d-flex justify-content-between align-items-center" style="border-bottom:1px solid rgba(255,255,255,0.08)">
                                    <span class="text-white fw-semibold small">Notifications</span>
                                    <a asp-controller="Notifications" asp-action="Index" class="text-gradient small" style="text-decoration:none">View all</a>
                                </li>
                                <li id="notifItems"><div class="px-3 py-4 text-center text-muted small">No new notifications</div></li>
                            </ul>
                        </div>

                        <!-- User Dropdown -->
                        <div class="dropdown ms-2">
                            <a class="btn btn-outline-light btn-sm dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-person-circle me-1"></i>@User.Identity.Name?.Split('@')[0]
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end dropdown-menu-dark" style="background:rgba(15,18,25,0.95);border:1px solid rgba(255,255,255,0.1);backdrop-filter:blur(10px)">
                                <li><a class="dropdown-item" asp-controller="Goals" asp-action="Index"><i class="bi bi-speedometer2 me-2"></i>My Dashboard</a></li>
                                <li><a class="dropdown-item" asp-controller="Mentorship" asp-action="MySessions"><i class="bi bi-chat-dots me-2"></i>Messages & Sessions</a></li>
                                <li><a class="dropdown-item" asp-controller="Notifications" asp-action="Index"><i class="bi bi-bell me-2"></i>Notifications</a></li>
                                <li><a class="dropdown-item" asp-controller="Resume" asp-action="Builder"><i class="bi bi-file-earmark-person me-2"></i>Resume Builder</a></li>
                                <li><hr class="dropdown-divider" style="border-color:rgba(255,255,255,0.1)"></li>
                                <li>
                                    <form asp-controller="Account" asp-action="Logout" method="post">
                                        <button type="submit" class="dropdown-item text-danger"><i class="bi bi-box-arrow-right me-2"></i>Logout</button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login" class="btn btn-outline-light btn-sm">Login</a>
                        <a asp-controller="Account" asp-action="Register" class="btn btn-primary btn-sm">Get Started</a>
                    }
                </div>
            </div>
        </div>
    </nav>

    <main>
        @if (TempData["Success"] != null)
        {
            <div class="alert-toast alert-toast-success">
                <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert-toast alert-toast-error">
                <i class="bi bi-exclamation-circle me-2"></i>@TempData["Error"]
            </div>
        }
        @RenderBody()
    </main>

    <footer class="footer mt-auto">
        <div class="container">
            <div class="row g-4 py-5">
                <div class="col-lg-4">
                    <h5 class="fw-bold mb-3"><i class="bi bi-compass me-2 text-primary"></i>CareerPath</h5>
                    <p class="text-muted small">Empowering individuals to make informed career decisions through personalized assessments, mentorship, and skill development resources.</p>
                </div>
                <div class="col-lg-2">
                    <h6 class="fw-semibold mb-3">Explore</h6>
                    <ul class="list-unstyled small">
                        <li><a asp-controller="Assessment" asp-action="Index" class="footer-link">Career Assessment</a></li>
                        <li><a asp-controller="Resources" asp-action="Index" class="footer-link">Resources</a></li>
                        <li><a asp-controller="CareerPath" asp-action="Index" class="footer-link">Career Paths</a></li>
                    </ul>
                </div>
                <div class="col-lg-2">
                    <h6 class="fw-semibold mb-3">Connect</h6>
                    <ul class="list-unstyled small">
                        <li><a asp-controller="Mentorship" asp-action="Index" class="footer-link">Find a Mentor</a></li>
                        <li><a asp-controller="Networking" asp-action="Events" class="footer-link">Events</a></li>
                        <li><a asp-controller="Networking" asp-action="Community" class="footer-link">Community</a></li>
                    </ul>
                </div>
                <div class="col-lg-2">
                    <h6 class="fw-semibold mb-3">Tools</h6>
                    <ul class="list-unstyled small">
                        <li><a asp-controller="Jobs" asp-action="Index" class="footer-link">Job Board</a></li>
                        <li><a asp-controller="Goals" asp-action="Index" class="footer-link">Goals</a></li>
                        <li><a asp-controller="Resume" asp-action="Builder" class="footer-link">Resume Builder</a></li>
                    </ul>
                </div>
                <div class="col-lg-2">
                    <h6 class="fw-semibold mb-3">Account</h6>
                    <ul class="list-unstyled small">
                        @if (User.Identity!.IsAuthenticated)
                        {
                            <li><a asp-controller="Goals" asp-action="Index" class="footer-link">Dashboard</a></li>
                            <li><a asp-controller="Jobs" asp-action="Tracker" class="footer-link">Application Tracker</a></li>
                        }
                        else
                        {
                            <li><a asp-controller="Account" asp-action="Register" class="footer-link">Register</a></li>
                            <li><a asp-controller="Account" asp-action="Login" class="footer-link">Login</a></li>
                        }
                    </ul>
                </div>
            </div>
            <div class="border-top border-secondary pt-3 pb-3 text-center text-muted small">
                &copy; 2026 CareerPath. Aptech eProject — Semester 3. All rights reserved.
            </div>
        </div>
    </footer>

    <!-- Floating Chatbot UI -->
    <div id="ai-chatbot-container" class="position-fixed" style="bottom: 20px; right: 20px; z-index: 1050; display: none;">
        <div class="card shadow-lg" style="width: 350px; border-radius: 15px; border: 1px solid rgba(255,215,0,0.3); background: rgba(15,18,25,0.95); backdrop-filter: blur(10px); overflow: hidden;">
            <div class="card-header text-white d-flex justify-content-between align-items-center" style="background: linear-gradient(135deg, #0f172a, #1e293b); border-bottom: 1px solid rgba(255,215,0,0.2);">
                <div class="d-flex align-items-center">
                    <i class="bi bi-robot fs-4 me-2 text-gradient-gold"></i>
                    <h6 class="mb-0 fw-bold">Career AI Assistant</h6>
                </div>
                <button type="button" class="btn-close btn-close-white" aria-label="Close" onclick="toggleChatbot()"></button>
            </div>
            <div class="card-body" id="chat-messages" style="height: 350px; overflow-y: auto; display: flex; flex-direction: column; gap: 10px; padding: 15px;">
                <div class="text-start">
                    <div class="d-inline-block p-2 rounded-3 text-white" style="background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.05); max-width: 85%;">
                        Hello! I am your AI career assistant. How can I help you today?
                    </div>
                </div>
            </div>
            <div class="card-footer" style="background: rgba(0,0,0,0.2); border-top: 1px solid rgba(255,255,255,0.1);">
                <div class="input-group">
                    <input type="text" id="chat-input" class="form-control text-white" placeholder="Ask about your career..." style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);" onkeypress="if(event.key === 'Enter') sendChatMessage()">
                    <button class="btn btn-gold text-dark fw-bold" type="button" onclick="sendChatMessage()">
                        <i class="bi bi-send-fill"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <button id="chatbot-toggle-btn" class="btn btn-gold text-dark position-fixed shadow-lg rounded-circle" style="bottom: 20px; right: 20px; width: 60px; height: 60px; z-index: 1040; display: flex; align-items: center; justify-content: center;" onclick="toggleChatbot()">
        <i class="bi bi-robot fs-3"></i>
    </button>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    @if (User.Identity!.IsAuthenticated)
    {
        <script>
        // ── Notification Bell ──────────────────────────────────────────────────
        async function loadNotifications() {
            try {
                const [countRes, previewRes] = await Promise.all([
                    fetch('/Notifications/UnreadCount'),
                    fetch('/Notifications/Preview')
                ]);
                const { count } = await countRes.json();
                const items    = await previewRes.json();

                const badge = document.getElementById('notifBadge');
                if (badge) {
                    badge.textContent = count > 9 ? '9+' : count;
                    badge.style.display = count > 0 ? 'inline-block' : 'none';
                }

                const list = document.getElementById('notifItems');
                if (!list) return;
                if (!items.length) {
                    list.innerHTML = '<div class="px-3 py-4 text-center text-muted small">No notifications yet</div>';
                    return;
                }
                list.innerHTML = items.map(n => `
                    <li>
                        <form action="/Notifications/MarkRead/${n.id}" method="post" style="margin:0">
                            <button type="submit" class="dropdown-item py-2 px-3 d-flex gap-2 align-items-start" style="white-space:normal;${n.isRead ? 'opacity:0.6' : ''}">
                                <i class="bi ${n.icon} ${n.iconColor} flex-shrink-0 mt-1"></i>
                                <div>
                                    <div class="text-white small fw-semibold">${n.title} ${!n.isRead ? '<span style="width:7px;height:7px;background:#ff2d6b;border-radius:50%;display:inline-block;margin-left:4px;vertical-align:middle"></span>' : ''}</div>
                                    <div class="text-muted" style="font-size:0.72rem">${n.message}</div>
                                    <div class="text-muted" style="font-size:0.68rem;margin-top:2px">${n.time}</div>
                                </div>
                            </button>
                        </form>
                    </li>
                    <li><hr class="dropdown-divider m-0" style="border-color:rgba(255,255,255,0.05)"></li>
                `).join('');
            } catch(e) { /* fail silently */ }
        }

        loadNotifications();
        setInterval(loadNotifications, 30000); // poll every 30s

        // Refresh when bell dropdown opens
        document.getElementById('notifBell')?.addEventListener('show.bs.dropdown', loadNotifications);
        </script>
    }
</body>
</html>
