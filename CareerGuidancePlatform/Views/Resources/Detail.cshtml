@model CareerGuidancePlatform.Models.Resource
@{ ViewData["Title"] = Model.Title; }

<div class="page-header">
    <div class="container">
        <div class="d-flex gap-2 mb-2 flex-wrap">
            <span class="tag tag-blue">@Model.Type</span>
            <span class="tag tag-purple">@Model.Industry</span>
            <span class="tag tag-green">@Model.SkillCategory</span>
        </div>
        <h1 class="text-white fw-bold">@Model.Title</h1>
        <p class="text-muted"><i class="bi bi-person-workspace me-1"></i>Provided by: @Model.Provider</p>
    </div>
</div>

<section>
    <div class="container">
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="card-glass mb-4">
                    @if (!string.IsNullOrEmpty(Model.ThumbnailUrl))
                    {
                        <div class="mb-4 text-center">
                            <img src="@Model.ThumbnailUrl" alt="@Model.Title" class="img-fluid rounded-xl" style="max-height: 400px; object-fit: cover;" />
                        </div>
                    }
                    <h5 class="text-white fw-bold mb-3"><i class="bi bi-info-circle me-2 text-gradient"></i>Overview</h5>
                    <p class="text-muted">@Model.Description</p>
                </div>
            </div>
            
            <div class="col-lg-4">
                <div class="card-glass mb-4">
                    <h6 class="text-white fw-semibold mb-3">Resource Details</h6>
                    <div class="mb-3">
                        <span class="text-muted small d-block">Cost</span>
                        <span class="text-gradient fw-bold">@(Model.IsFree ? "Free" : "Paid")</span>
                    </div>
                    <div class="mb-3">
                        <span class="text-muted small d-block">Difficulty Level</span>
                        <span class="tag @(Model.DifficultyLevel == 1 ? "tag-green" : Model.DifficultyLevel == 2 ? "tag-gold" : "tag-red")">
                            @(Model.DifficultyLevel == 1 ? "Beginner" : Model.DifficultyLevel == 2 ? "Intermediate" : "Advanced")
                        </span>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.Duration))
                    {
                        <div class="mb-3">
                            <span class="text-muted small d-block">Duration</span>
                            <span class="text-white small">@Model.Duration</span>
                        </div>
                    }
                    <div class="mb-3">
                        <span class="text-muted small d-block">Date Added</span>
                        <span class="text-muted small">@Model.CreatedAt.ToString("MMM dd, yyyy")</span>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Model.Url))
                {
                    <a href="@Model.Url" target="_blank" class="btn btn-primary w-100 mb-3">
                        <i class="bi bi-box-arrow-up-right me-2"></i>Access Resource
                    </a>
                }
            </div>
        </div>

        @if (ViewBag.Related != null && ((List<CareerGuidancePlatform.Models.Resource>)ViewBag.Related).Any())
        {
            <div class="mt-5">
                <h4 class="text-white fw-bold mb-4">Related Resources</h4>
                <div class="row g-4">
                    @foreach (var related in (List<CareerGuidancePlatform.Models.Resource>)ViewBag.Related)
                    {
                        <div class="col-md-4">
                            <a asp-action="Detail" asp-route-id="@related.Id" style="text-decoration:none">
                                <div class="card-glass h-100">
                                    <span class="tag tag-blue mb-2">@related.Type</span>
                                    <h6 class="text-white fw-semibold mb-2">@related.Title</h6>
                                    <p class="text-muted small mb-0">Provided by @related.Provider</p>
                                </div>
                            </a>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</section>
