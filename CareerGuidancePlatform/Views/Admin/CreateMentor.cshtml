@model CareerGuidancePlatform.Models.Mentor
@{ ViewData["Title"] = "Add Mentor"; }
@await Html.PartialAsync("_AdminNav")

<div class="page-header">
    <div class="container">
        <a asp-action="ManageMentors" class="text-muted small text-decoration-none"><i class="bi bi-arrow-left me-1"></i>Back to Mentors</a>
        <h1 class="text-white fw-bold mt-2">Add New Mentor</h1>
    </div>
</div>

<section class="container">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card-glass">
                <form asp-action="CreateMentor" method="post">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Full Name *</label>
                            <input asp-for="Name" class="form-control" placeholder="Sarah Chen" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Email *</label>
                            <input asp-for="Email" class="form-control" type="email" placeholder="sarah@mentor.com" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Specialization *</label>
                            <input asp-for="Specialization" class="form-control" placeholder="Software Engineering, Data Science..." required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Industry *</label>
                            <select asp-for="Industry" class="form-select">
                                <option value="Technology">Technology</option>
                                <option value="Design">Design</option>
                                <option value="Security">Security</option>
                                <option value="Management">Management</option>
                                <option value="Finance">Finance</option>
                                <option value="Healthcare">Healthcare</option>
                                <option value="General">General</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Bio *</label>
                            <textarea asp-for="Bio" class="form-control" rows="4" placeholder="Mentor's background, experience and mentoring style..." required></textarea>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Years of Experience *</label>
                            <input asp-for="YearsOfExperience" class="form-control" type="number" min="0" max="50" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Rating (0-5)</label>
                            <input asp-for="Rating" class="form-control" type="number" step="0.1" min="0" max="5" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Total Sessions</label>
                            <input asp-for="TotalSessions" class="form-control" type="number" min="0" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Availability</label>
                            <input asp-for="Availability" class="form-control" placeholder="Mon-Fri 6PM-9PM / Weekends 10AM-2PM" />
                        </div>
                        <div class="col-12">
                            <div class="form-check form-switch">
                                <input asp-for="IsAvailable" class="form-check-input" type="checkbox" checked />
                                <label class="form-check-label text-muted" asp-for="IsAvailable">Currently accepting bookings</label>
                            </div>
                        </div>
                    </div>
                    <div class="d-flex gap-3 mt-4">
                        <button type="submit" class="btn btn-primary flex-grow-1"><i class="bi bi-person-plus me-2"></i>Add Mentor</button>
                        <a asp-action="ManageMentors" class="btn btn-outline-primary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>
