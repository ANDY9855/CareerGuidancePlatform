@model List<CareerGuidancePlatform.Models.ApplicationUser>
@{
    ViewData["Title"] = "Manage Users";
    var userRoles = (Dictionary<string, string>)ViewBag.UserRoles;
    string[] allRoles = ViewBag.AllRoles;
}
@await Html.PartialAsync("_AdminNav")

<div class="page-header">
    <div class="container">
        <h1 class="text-white fw-bold mb-0"><i class="bi bi-people me-2 text-gradient-gold"></i>Manage Users</h1>
        <p class="text-muted mb-0">@Model.Count total registered accounts</p>
    </div>
</div>

<section class="container">
    <div class="card-glass">
        <div class="table-responsive">
            <table class="table table-dark table-hover mb-0 align-middle">
                <thead>
                    <tr>
                        <th>User</th><th>Details</th><th>Joined</th>
                        <th>Current Role</th><th>Change Role</th><th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        var role = userRoles.ContainsKey(user.Id) ? userRoles[user.Id] : "User";
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="mentor-avatar" style="width:36px;height:36px;font-size:0.85rem">
                                        @(user.FullName != null && user.FullName.Length > 0 ? user.FullName[0] : 'U')
                                    </div>
                                    <div>
                                        <div class="text-white small fw-semibold">@user.FullName</div>
                                        <div class="text-muted" style="font-size:0.72rem">@user.Email</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div class="text-muted small">@(user.Industry ?? "—")</div>
                                <div class="text-muted" style="font-size:0.72rem">@(user.CurrentRole ?? "—")</div>
                            </td>
                            <td><span class="text-muted small">@user.CreatedAt.ToString("MMM dd, yyyy")</span></td>
                            <td>
                                <span class="tag @(role=="Admin"?"tag-gold":role=="Mentor"?"tag-purple":"tag-blue")">@role</span>
                            </td>
                            <td>
                                <form asp-action="ChangeRole" method="post" class="d-flex gap-2">
                                    <input type="hidden" name="userId" value="@user.Id" />
                                    <select name="newRole" class="form-select form-select-sm" style="max-width:130px">
                                        @foreach (var r in allRoles)
                                        {
                                            <option value="@r" selected="@(role == r)">@r</option>
                                        }
                                    </select>
                                    <button type="submit" class="btn btn-sm btn-outline-primary">Set</button>
                                </form>
                            </td>
                            <td>
                                @if (user.Email != "admin@career.com")
                                {
                                    <form asp-action="DeleteUser" method="post" class="d-inline"
                                          onsubmit="return confirm('Delete @user.FullName? This cannot be undone.')">
                                        <input type="hidden" name="id" value="@user.Id" />
                                        <button class="btn btn-sm btn-outline-danger"><i class="bi bi-person-x me-1"></i>Delete</button>
                                    </form>
                                }
                                else
                                {
                                    <span class="tag tag-gold"><i class="bi bi-shield-lock me-1"></i>Protected</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>
