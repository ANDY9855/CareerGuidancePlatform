@model IEnumerable<CareerGuidancePlatform.Models.JobListing>
@{ ViewData["Title"] = "Manage Jobs"; }
@await Html.PartialAsync("_AdminNav")

<div class="page-header">
    <div class="container d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div>
            <h1 class="text-white fw-bold mb-0"><i class="bi bi-briefcase me-2 text-gradient-gold"></i>Manage Jobs</h1>
            <p class="text-muted mb-0">@Model.Count() total listings</p>
        </div>
        <a asp-action="CreateJob" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>Post New Job</a>
    </div>
</div>

<section class="container">
    <div class="card-glass">
        <div class="table-responsive">
            <table class="table table-dark table-hover mb-0 align-middle">
                <thead>
                    <tr>
                        <th>Job Title</th><th>Company</th><th>Type</th>
                        <th>Industry</th><th>Salary</th><th>Deadline</th>
                        <th>Status</th><th>Apps</th><th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var j in Model)
                    {
                        <tr>
                            <td>
                                <span class="text-white fw-semibold small">@j.Title</span><br>
                                <span class="text-muted" style="font-size:0.72rem"><i class="bi bi-geo-alt me-1"></i>@j.Location</span>
                            </td>
                            <td><span class="text-muted small">@j.Company</span></td>
                            <td><span class="tag @(j.Type=="Internship"?"tag-gold":j.Type=="Remote"?"tag-green":"tag-blue")">@j.Type</span></td>
                            <td><span class="tag tag-purple">@j.Industry</span></td>
                            <td><span class="text-muted small">@j.SalaryRange</span></td>
                            <td><span class="text-muted small">@j.Deadline.ToString("MMM dd, yyyy")</span></td>
                            <td>
                                <span class="tag @(j.IsActive?"tag-green":"tag-red")">@(j.IsActive?"Active":"Inactive")</span>
                            </td>
                            <td><span class="tag tag-blue">@j.Applications.Count</span></td>
                            <td>
                                <div class="d-flex gap-1 flex-wrap">
                                    <a asp-action="EditJob" asp-route-id="@j.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form asp-action="ToggleJob" asp-route-id="@j.Id" method="post" class="d-inline">
                                        <button class="btn btn-sm @(j.IsActive?"btn-outline-warning":"btn-outline-success")" title="@(j.IsActive?"Deactivate":"Activate")">
                                            <i class="bi @(j.IsActive?"bi-pause-circle":"bi-play-circle")"></i>
                                        </button>
                                    </form>
                                    <form asp-action="DeleteJob" asp-route-id="@j.Id" method="post" class="d-inline"
                                          onsubmit="return confirm('Delete this job listing?')">
                                        <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>
