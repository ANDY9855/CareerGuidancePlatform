@model CareerGuidancePlatform.Models.NetworkingEvent
@{ ViewData["Title"] = "Create Event"; }
@await Html.PartialAsync("_AdminNav")

<div class="page-header">
    <div class="container">
        <a asp-action="ManageEvents" class="text-muted small text-decoration-none"><i class="bi bi-arrow-left me-1"></i>Back to Events</a>
        <h1 class="text-white fw-bold mt-2">Create Networking Event</h1>
    </div>
</div>

<section class="container">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card-glass">
                <form asp-action="CreateEvent" method="post">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label">Event Title *</label>
                            <input asp-for="Title" class="form-control" placeholder="e.g. Pakistan Tech Summit 2026" required />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Description *</label>
                            <textarea asp-for="Description" class="form-control" rows="3" placeholder="What attendees can expect..." required></textarea>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Event Type *</label>
                            <select asp-for="EventType" class="form-select">
                                <option value="Conference">Conference</option>
                                <option value="Webinar">Webinar</option>
                                <option value="Meetup">Meetup</option>
                                <option value="Workshop">Workshop</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Industry *</label>
                            <select asp-for="Industry" class="form-select">
                                <option value="Technology">Technology</option>
                                <option value="Design">Design</option>
                                <option value="Security">Security</option>
                                <option value="Management">Management</option>
                                <option value="Finance">Finance</option>
                                <option value="General">General</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Bootstrap Icon Class</label>
                            <input asp-for="IconClass" class="form-control" placeholder="bi-calendar-event" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Organizer *</label>
                            <input asp-for="Organizer" class="form-control" placeholder="e.g. Tech Pakistan" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Event Date & Time *</label>
                            <input asp-for="EventDate" class="form-control" type="datetime-local" required />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Location *</label>
                            <input asp-for="Location" class="form-control" placeholder="Karachi Expo Centre / Online (Zoom)" required />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Registration URL (optional)</label>
                            <input asp-for="RegistrationUrl" class="form-control" type="url" placeholder="https://..." />
                        </div>
                        <div class="col-12">
                            <div class="form-check form-switch">
                                <input asp-for="IsOnline" class="form-check-input" type="checkbox" />
                                <label class="form-check-label text-muted" asp-for="IsOnline">Online event</label>
                            </div>
                        </div>
                    </div>
                    <div class="d-flex gap-3 mt-4">
                        <button type="submit" class="btn btn-primary flex-grow-1"><i class="bi bi-calendar-plus me-2"></i>Create Event</button>
                        <a asp-action="ManageEvents" class="btn btn-outline-primary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>
