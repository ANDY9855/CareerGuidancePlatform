@model CareerGuidancePlatform.Models.JobListing
@{ ViewData["Title"] = Model.Title + " - " + Model.Company; }

<div class="page-header">
    <div class="container">
        <div class="d-flex gap-2 mb-2 flex-wrap">
            <span class="tag @(Model.Type=="Internship"?"tag-gold":"tag-blue")">@Model.Type</span>
            <span class="tag tag-purple">@Model.Industry</span>
        </div>
        <h1 class="text-white fw-bold">@Model.Title</h1>
        <p class="text-muted"><i class="bi bi-building me-1"></i>@Model.Company &nbsp;|&nbsp; <i class="bi bi-geo-alt me-1"></i>@Model.Location</p>
    </div>
</div>

<section>
    <div class="container">
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="card-glass mb-4">
                    <h5 class="text-white fw-bold mb-3"><i class="bi bi-info-circle me-2 text-gradient"></i>Job Description</h5>
                    <p class="text-muted">@Model.Description</p>
                </div>
                <div class="card-glass mb-4">
                    <h5 class="text-white fw-bold mb-3"><i class="bi bi-check2-square me-2 text-gradient"></i>Requirements</h5>
                    <ul class="text-muted" style="padding-left:1.2rem">
                        @foreach (var req in Model.Requirements.Split(','))
                        { <li class="mb-1">@req.Trim()</li> }
                    </ul>
                </div>
                @if (Model.Reviews.Any())
                {
                    <div class="card-glass">
                        <h5 class="text-white fw-bold mb-3"><i class="bi bi-chat-quote me-2 text-gradient-gold"></i>Employer Reviews</h5>
                        @foreach (var rev in Model.Reviews)
                        {
                            <div class="card-glass mb-3" style="border-left:3px solid var(--accent-gold)">
                                <div class="d-flex justify-content-between">
                                    <span class="text-white small fw-semibold">@rev.ReviewerName</span>
                                    <div class="stars" style="font-size:0.8rem">@string.Concat(Enumerable.Repeat("★", rev.Rating))</div>
                                </div>
                                <p class="text-muted small mt-1 mb-0">@rev.ReviewText</p>
                            </div>
                        }
                    </div>
                }
            </div>
            <div class="col-lg-4">
                <div class="card-glass mb-4">
                    <h6 class="text-white fw-semibold mb-3">Job Details</h6>
                    <div class="mb-3"><span class="text-muted small d-block">Salary</span><span class="text-gradient fw-bold">@Model.SalaryRange</span></div>
                    <div class="mb-3"><span class="text-muted small d-block">Type</span><span class="tag tag-blue">@Model.Type</span></div>
                    <div class="mb-3"><span class="text-muted small d-block">Location</span><span class="text-white small">@Model.Location</span></div>
                    <div class="mb-3"><span class="text-muted small d-block">Deadline</span><span class="text-white small">@Model.Deadline.ToString("MMMM dd, yyyy")</span></div>
                    <div class="mb-3"><span class="text-muted small d-block">Posted</span><span class="text-muted small">@Model.PostedAt.ToString("MMM dd, yyyy")</span></div>
                </div>
                @if (User.Identity!.IsAuthenticated)
                {
                    <form asp-action="Apply" method="post">
                        <input type="hidden" name="jobId" value="@Model.Id" />
                        <button type="submit" class="btn btn-primary w-100 mb-3">
                            <i class="bi bi-send me-2"></i>Apply Now
                        </button>
                    </form>
                    <a asp-action="Tracker" class="btn btn-outline-primary w-100">My Applications</a>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login" class="btn btn-primary w-100">Login to Apply</a>
                }
            </div>
        </div>
    </div>
</section>
