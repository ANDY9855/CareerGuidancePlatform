@model List<CareerGuidancePlatform.Models.JobListing>
@{ ViewData["Title"] = "Job Board"; }

<div class="page-header">
    <div class="container">
        <span class="section-badge">Opportunities</span>
        <h1 class="text-white fw-bold mt-2">Jobs & Internships Board</h1>
        <p class="text-muted">Curated listings matched to your profile and career goals</p>
    </div>
</div>

<section>
    <div class="container">
        <div class="card-glass mb-5">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label">Search</label>
                    <input name="search" class="form-control" placeholder="Job title or company..." value="@ViewBag.Search" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Type</label>
                    <select name="type" class="form-select">
                        <option value="">All Types</option>
                        @foreach (var t in (List<string>)ViewBag.Types) { <option value="@t">@t</option> }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Industry</label>
                    <select name="industry" class="form-select">
                        <option value="">All Industries</option>
                        @foreach (var i in (List<string>)ViewBag.Industries) { <option value="@i">@i</option> }
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">Search</button>
                </div>
            </form>
        </div>

        <div class="d-flex justify-content-between align-items-center mb-4">
            <span class="text-muted small">@Model.Count job(s) found</span>
            @if (User.Identity!.IsAuthenticated)
            { <a asp-action="Tracker" class="btn btn-outline-primary btn-sm"><i class="bi bi-list-check me-1"></i>My Applications</a> }
        </div>

        <div class="row g-4">
            @foreach (var j in Model)
            {
                <div class="col-12">
                    <div class="card-glass">
                        <div class="row align-items-center">
                            <div class="col-md-7">
                                <div class="d-flex gap-2 mb-2 flex-wrap">
                                    <span class="tag @(j.Type=="Internship"?"tag-gold":j.Type=="Remote"?"tag-green":"tag-blue")">@j.Type</span>
                                    <span class="tag tag-purple">@j.Industry</span>
                                </div>
                                <h5 class="text-white fw-bold mb-1">@j.Title</h5>
                                <p class="text-muted small mb-1"><i class="bi bi-building me-1"></i>@j.Company &nbsp;|&nbsp; <i class="bi bi-geo-alt me-1"></i>@j.Location</p>
                                <p class="text-muted small"><i class="bi bi-cash me-1"></i>@j.SalaryRange &nbsp;|&nbsp; <i class="bi bi-calendar me-1"></i>Deadline: @j.Deadline.ToString("MMM dd, yyyy")</p>
                            </div>
                            <div class="col-md-5 text-md-end mt-3 mt-md-0">
                                <p class="text-muted small mb-3">@(j.Description.Length > 80 ? j.Description[..80] + "..." : j.Description)</p>
                                <a asp-action="Detail" asp-route-id="@j.Id" class="btn btn-primary btn-sm">View & Apply</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>
